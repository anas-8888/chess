# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=smart-chess

# JWT Configuration
JWT_SECRET=your-strong-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Session Management
# Options: 'single', 'multiple', 'limited'
SESSION_POLICY=single
MAX_SESSIONS=5

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3003,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# Logging
LOG_LEVEL=info 

# Uploaded user thumbnails base URL
THUBNAILS_URL=http://localhost:3000/thumbnails

# Game cleanup (auto close stale waiting/active games)
# Stale timeout formula:
# timeoutSeconds = clamp(initial_time * GAME_STALE_MULTIPLIER + GAME_STALE_GRACE_SECONDS,
#                        GAME_STALE_MIN_SECONDS,
#                        GAME_STALE_MAX_SECONDS)
GAME_CLEANUP_INTERVAL_MS=60000
GAME_STALE_MULTIPLIER=3
GAME_STALE_GRACE_SECONDS=300
GAME_STALE_MIN_SECONDS=900
GAME_STALE_MAX_SECONDS=43200
